word = input()
sum = 0

for i in word:
    if 'a' <= i <= 'z':
        sum = sum + (ord(i) - ord('a') + 1)
    else:
        sum = sum + (ord(i) - ord('A') + 27)

if sum == 1:
    print("It is a prime word.")
else:
    prime = True
    for i in range(2, sum):
        if sum % i == 0:
            prime = False

    if prime == True:
        print("It is a prime word.")
    else:
        print("It is not a prime word.")