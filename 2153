word = input()
total = 0

for i in word:
    if 'a' <= i <= 'z':
        total += ord(i) - ord('a') + 1
    else:
        total += ord(i) - ord('A') + 27

prime = True

if total > 1:
    for i in range(2, total):
        if total % i == 0:
            prime = False
            break   # 약수 찾으면 바로 종료

if prime==True:
    print("It is a prime word.")
else:
    print("It is not a prime word.")